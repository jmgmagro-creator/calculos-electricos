    },
    Al: {
      XLPE: { 2:[15.5,21,28,36,50,67,84,105,128,164,199,232,264,300,360,414], 3:[13.5,18.5,25,32,44,59,73,91,110,141,171,200,230,262,310,358] },
      PVC:  { 2:[12,16.5,22,28,39,53,68,84,103,131,159,184,211,241,285,328], 3:[10.5,14,18.5,24,32,43,57,70,84,107,129,149,170,194,227,261] }
    }
  },
  C: {
    Cu: {
      XLPE: { 2:[26,36,49,63,86,115,149,185,225,289,352,410,473,542,641,741], 3:[22,30,40,51,70,94,119,147,179,229,278,322,371,424,500,576] },
      PVC:  { 2:[19.5,27,36,46,63,85,112,138,168,213,258,299,344,392,461,530], 3:[17.5,24,32,41,57,76,96,119,144,184,223,259,299,341,403,464] }
    },
    Al: {
      XLPE: { 2:[20,28,38,49,67,90,115,143,174,223,271,316,364,418,494,571], 3:[17,23,31,40,54,73,92,113,138,177,214,249,286,327,386,445] },
      PVC:  { 2:[15,21,28,36,49,66,86,107,130,165,200,232,265,303,357,410], 3:[13.5,18.5,25,32,44,59,74,92,111,142,172,200,230,263,311,358] }
    }
  },
  E: {
    Cu: {
      XLPE: { 2:[26,36,49,63,86,115,149,185,225,289,352,410,473,542,641,741], 3:[23,32,42,54,75,100,127,158,192,246,298,346,399,456,538,621] },
      PVC:  { 2:[19.5,27,36,46,63,85,112,138,168,213,258,299,344,392,461,530], 3:[18.5,25,34,43,60,80,101,126,153,196,238,276,319,364,430,497] }
    },
    Al: {
      XLPE: { 2:[20,28,38,49,67,90,115,143,174,223,271,316,364,418,494,571], 3:[17.5,25,32,42,58,77,98,122,149,190,230,268,308,352,416,480] },
      PVC:  { 2:[15,21,28,36,49,66,86,107,130,165,200,232,265,303,357,410], 3:[14,19.5,26,33,46,61,78,97,118,151,183,213,246,281,332,383] }
    }
  },
  F: {
    Cu: {
      XLPE: { 2:[31,42,57,73,100,133,171,214,260,334,407,474,547,628,744,859], 3:[26,36,49,63,86,115,149,185,225,289,352,410,473,542,641,741] },
      PVC:  { 2:[23,31,42,54,74,99,131,162,197,250,304,352,406,463,546,629], 3:[22,30,40,51,70,94,119,147,179,229,278,322,371,424,500,576] }
    },
    Al: {
      XLPE: { 2:[24,32,44,57,77,103,132,165,201,258,314,366,422,485,574,663], 3:[20,28,38,49,67,89,115,143,174,223,271,316,364,418,494,571] },
      PVC:  { 2:[17.5,24,32,42,57,76,101,125,151,193,234,272,313,357,421,485], 3:[17,23,31,39,54,73,92,113,138,177,214,249,286,327,386,445] }
    }
  }
};

const K_FACTORS = { Cu:{ XLPE:143, PVC:115 }, Al:{ XLPE:94, PVC:76 } };
const RHO_VALUES = { Cu:{ XLPE:0.0225, PVC:0.021 }, Al:{ XLPE:0.036, PVC:0.033 } };
const MAX_TEMPS = { XLPE:90, PVC:70 };

// ============================================
// ESTADO DE LA APLICACIÓN
// ============================================

let circuits = [{
  id:1, tag:'001', desc:'Bomba Pasteurización',
  power_kw:18.5, simult:1.0, utiliz:0.85, efficiency:0.86,
  voltage:400, cosPhi:0.88, length:100, phases:3,
  startType:'Converter', method:'E', material:'Cu', insulation:'XLPE',
  loadedCond:3, ambientTemp:40, kg:1.0, maxCdt:5.0,
  ikMax:6, icu:15, tClear:0.1
}];

let results = {};
let activeTab = 0;
let currentView = 'edit';

// ============================================
// MOTOR DE CÁLCULO
// ============================================

function getKt(insulation, ambientTemp) {
  const tMax = MAX_TEMPS[insulation];
  const ratio = (tMax - ambientTemp) / (tMax - 30);
  return ratio > 0 ? Math.sqrt(ratio) : 0;
}

function getIzTable(method, material, insulation, loaded) {
  try { return IZ[method][material][insulation][loaded]; }
  catch(e) { return null; }
}

function calcular(c) {
  const r = {};
  const sinPhi = Math.sqrt(1 - c.cosPhi * c.cosPhi);

  // Potencias
  r.pDemanded = c.power_kw * c.simult * c.utiliz;
  r.pElectric = c.power_kw / c.efficiency;

  // Corriente Ib
  if (c.phases === 3) {
    r.Ib = (r.pElectric * 1000) / (Math.sqrt(3) * c.voltage * c.cosPhi);
  } else {
    r.Ib = (r.pElectric * 1000) / (c.voltage * c.cosPhi);
  }

  // Corriente de diseño cable (×1.25 motores, ITC-BT-47)
  const isMotor = ['Direct','Star-Delta','Soft Starter','Converter'].includes(c.startType);
  r.Idesign = isMotor ? r.Ib * 1.25 : r.Ib;

  // Protección In
  r.In = PROT_SIZES.find(p => p >= r.Ib) || null;
  r.checkIbIn = r.In !== null && r.Ib <= r.In;

  // Factor temperatura
  r.kt = getKt(c.insulation, c.ambientTemp);
  r.kg = c.kg;

  // Tabla Iz
  const izTable = getIzTable(c.method, c.material, c.insulation, c.loadedCond);
  if (!izTable || !r.In) { r.error = 'Tabla Iz no disponible para esta configuración'; return r; }

  // CRITERIO TÉRMICO
  r.secThermal = null; r.izBaseThermal = null; r.izCorrThermal = null; r.idxThermal = -1;
  for (let i = 0; i < SECTIONS.length; i++) {
    const izCorr = izTable[i] * r.kt * r.kg;
    if (izCorr >= r.In) {
      r.secThermal = SECTIONS[i];
      r.izBaseThermal = izTable[i];
      r.izCorrThermal = izCorr;
      r.idxThermal = i;
      break;
    }
  }
  r.checkThermal = r.izCorrThermal !== null && r.In <= r.izCorrThermal;
  if (r.secThermal === null) { r.error = 'Ninguna sección cumple térmicamente'; return r; }

  // CAÍDA DE TENSIÓN
  const rho = RHO_VALUES[c.material][c.insulation];
  const X = 0.08 / 1000;
  r.rho = rho;
  r.X_ohm_km = 0.08;

  const cdtFactor = c.phases === 3 ? Math.sqrt(3) : 2;
  function calcCdt(sec) {
    return cdtFactor * r.Idesign * c.length * ((rho / sec) * c.cosPhi + X * sinPhi);
  }

  r.cdtThermalV = calcCdt(r.secThermal);
  r.cdtThermalPct = (r.cdtThermalV / c.voltage) * 100;
  r.checkCdtThermal = r.cdtThermalPct <= c.maxCdt;

  // Sección por CDT (iterar)
  r.secCdt = null; r.idxCdt = -1;
  for (let i = r.idxThermal; i < SECTIONS.length; i++) {
    const pct = (calcCdt(SECTIONS[i]) / c.voltage) * 100;
    if (pct <= c.maxCdt) { r.secCdt = SECTIONS[i]; r.idxCdt = i; break; }
  }

  // SECCIÓN FINAL
  if (r.secCdt !== null) {
    const idxFinal = Math.max(r.idxThermal, r.idxCdt);
    r.secFinal = SECTIONS[idxFinal];
    r.izBaseFinal = izTable[idxFinal];
    r.izCorrFinal = izTable[idxFinal] * r.kt * r.kg;
    r.cdtFinalV = calcCdt(r.secFinal);
    r.cdtFinalPct = (r.cdtFinalV / c.voltage) * 100;
    r.checkCdtFinal = r.cdtFinalPct <= c.maxCdt;
    r.checkFinalCable = r.In <= r.izCorrFinal && r.cdtFinalPct <= c.maxCdt;
  } else {
    r.error = 'Ninguna sección cumple caída de tensión'; return r;
  }

  // CORTOCIRCUITO
  r.ikMaxOrigin = c.ikMax;
  const kFactor = K_FACTORS[c.material][c.insulation];
  r.kFactor = kFactor;

  if (c.ikMax > 0) {
    const Zred = c.voltage / (Math.sqrt(3) * c.ikMax * 1000);
    const Rcable = rho * c.length / r.secFinal;
    const Xcable = (0.08 / 1000) * c.length;
    const Zcable = Math.sqrt(Rcable * Rcable + Xcable * Xcable);
    if (c.phases === 3) {
      r.ikMinLoad = (0.95 * c.voltage) / (Math.sqrt(3) * (Zred + 2 * Zcable)) / 1000;
    } else {
      r.ikMinLoad = (0.95 * c.voltage) / (2 * (Zred + Zcable)) / 1000;
    }
  } else { r.ikMinLoad = 0; }

  r.icu = c.icu;
  r.checkIcu = c.icu >= c.ikMax;
  r.tMaxSC = r.ikMinLoad > 0 ? Math.pow((kFactor * r.secFinal) / (r.ikMinLoad * 1000), 2) : 999;
  r.tClear = c.tClear;
  r.checkThermalSC = c.tClear <= r.tMaxSC;
  r.finalCheck = r.checkIbIn && r.checkFinalCable && r.checkIcu && r.checkThermalSC;

  return r;
}

