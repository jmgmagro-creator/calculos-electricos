function renderTabs() {
  let html = '';
  circuits.forEach((c, i) => {
    const dot = results[i] ? `<span class="dot" style="background:${results[i].finalCheck ? '#2a8a50' : '#aa3030'}"></span>` : '';
    html += `<div class="tab${activeTab === i ? ' active' : ''}" onclick="setActive(${i})">${c.tag}${dot}</div>`;
  });
  html += `<div class="tab-add" onclick="addCircuit()">+</div>`;
  document.getElementById('tabBar').innerHTML = html;
}

function renderBottomBar() {
  const bar = document.getElementById('bottomBar');
  const keys = Object.keys(results);
  if (keys.length === 0) { bar.style.display = 'none'; return; }
  bar.style.display = 'flex';
  let html = '';
  circuits.forEach((c, i) => {
    const r = results[i];
    if (!r) return;
    const ok = r.finalCheck;
    html += `<div class="bottom-chip ${ok ? 'ok' : 'fail'}" onclick="setActive(${i});setView('results')">
      <div>${c.tag}</div><div>${r.secFinal ? r.secFinal + ' mm²' : 'ERR'}</div></div>`;
  });
  bar.innerHTML = html;
}

function sel(name, value, options) {
  return `<select onchange="updateField('${name}', this.value)">
    ${options.map(o => `<option value="${o}"${String(o) === String(value) ? ' selected' : ''}>${o}</option>`).join('')}
  </select>`;
}

function inp(name, value, step) {
  return `<input type="number" value="${value}" step="${step || 'any'}" onchange="updateField('${name}', this.value)">`;
}

function inpText(name, value) {
  return `<input type="text" value="${value}" onchange="updateFieldText('${name}', this.value)">`;
}

function fieldHtml(label, inputHtml) {
  return `<div class="field"><label>${label}</label>${inputHtml}</div>`;
}

function renderEdit() {
  const c = circuits[activeTab];
  let html = '';

  html += section('Identificación', '#5a7aaa', `
    <div class="grid2">
      ${fieldHtml('TAG', inpText('tag', c.tag))}
      ${fieldHtml('Fases', sel('phases', c.phases, [3, 1]))}
    </div>
    ${fieldHtml('Descripción', inpText('desc', c.desc))}
  `);

  html += section('Datos Eléctricos', '#3a7bd5', `
    <div class="grid2">
      ${fieldHtml('Potencia (kW)', inp('power_kw', c.power_kw, 0.01))}
      ${fieldHtml('Tensión (V)', inp('voltage', c.voltage))}
      ${fieldHtml('cos φ', inp('cosPhi', c.cosPhi, 0.01))}
      ${fieldHtml('Rendimiento η', inp('efficiency', c.efficiency, 0.01))}
      ${fieldHtml('Longitud (m)', inp('length', c.length))}
      ${fieldHtml('Arranque', sel('startType', c.startType, ['Direct','Star-Delta','Soft Starter','Converter','None']))}
    </div>
  `);

  html += section('Factores', '#4a8a5a', `
    <div class="grid2">
      ${fieldHtml('F. Simultaneidad', inp('simult', c.simult, 0.01))}
      ${fieldHtml('F. Utilización', inp('utiliz', c.utiliz, 0.01))}
    </div>
  `);

  html += section('Cable', '#8a6a3a', `
    <div class="grid2">
      ${fieldHtml('Método Inst.', sel('method', c.method, ['B1','C','E','F']))}
      ${fieldHtml('Material', sel('material', c.material, ['Cu','Al']))}
      ${fieldHtml('Aislamiento', sel('insulation', c.insulation, ['XLPE','PVC']))}
      ${fieldHtml('Cond. cargados', sel('loadedCond', c.loadedCond, [2, 3]))}
    </div>
  `);

  html += section('Corrección', '#7a5aaa', `
    <div class="grid2">
      ${fieldHtml('T. Ambiente (°C)', inp('ambientTemp', c.ambientTemp))}
      ${fieldHtml('F. Agrupamiento kg', inp('kg', c.kg, 0.01))}
    </div>
  `);

  html += section('Límites y Cortocircuito', '#aa5a5a', `
    <div class="grid2">
      ${fieldHtml('Máx C.D.T. (%)', inp('maxCdt', c.maxCdt, 0.1))}
      ${fieldHtml('Ik máx origen (kA)', inp('ikMax', c.ikMax, 0.01))}
      ${fieldHtml('Icu protección (kA)', inp('icu', c.icu, 0.1))}
      ${fieldHtml('t disparo prot. (s)', inp('tClear', c.tClear, 0.01))}
    </div>
  `);

  html += `<div class="actions">
    <button class="btn-calc" onclick="calcularUno()">CALCULAR</button>
    <button class="btn-all" onclick="calcularTodos()">TODOS</button>
    ${circuits.length > 1 ? `<button class="btn-del" onclick="removeCircuit()">✕</button>` : ''}
  </div>`;

  document.getElementById('content').innerHTML = html;
}

function renderResults() {
  const c = circuits[activeTab];
  const r = results[activeTab];

  if (!r) {
    document.getElementById('content').innerHTML = `<div class="empty-state"><div class="icon">⚡</div><div style="font-size:13px">Pulsa CALCULAR en la pestaña Datos</div></div>`;
    return;
  }

  if (r.error) {
    document.getElementById('content').innerHTML = `<div style="padding:16px;background:#2a1515;border:1px solid #5a2020;border-radius:6px;color:#ff8888;font-size:13px">⚠ ${r.error}</div>`;
    return;
  }

  let html = '';

  html += section('Corrientes', '#3a7bd5', `
    ${resRow('P eléctrica', fmt(r.pElectric), 'kW')}
    ${resRow('P demandada', fmt(r.pDemanded), 'kW')}
    ${resRow('Ib (estimada)', fmt(r.Ib), 'A')}
    ${resRow('I diseño cable', fmt(r.Idesign), 'A', undefined, true)}
    ${resRow('In protección', fmt(r.In, 0), 'A')}
    ${resRow('Ib ≤ In', fmt(r.Ib) + ' ≤ ' + fmt(r.In, 0), '', r.checkIbIn)}
  `);

  html += section('Criterio Térmico', '#4a8a5a', `
    ${resRow('Método', c.method)}
    ${resRow('kt (temperatura)', fmt(r.kt, 4))}
    ${resRow('kg (agrupamiento)', fmt(r.kg, 2))}
    ${resRow('Sección térmica', fmt(r.secThermal, 1), 'mm²', undefined, true)}
    ${resRow('Iz base', fmt(r.izBaseThermal), 'A')}
    ${resRow('Iz corregida', fmt(r.izCorrThermal), 'A')}
    ${resRow('In ≤ Iz', fmt(r.In, 0) + ' ≤ ' + fmt(r.izCorrThermal), '', r.checkThermal)}
  `);

  html += section('C.D.T. (sec. térmica)', '#8a6a3a', `
    ${resRow('ρ', fmt(r.rho, 4), 'Ω·mm²/m')}
    ${resRow('X', fmt(r.X_ohm_km, 2), 'Ω/km')}
    ${resRow('ΔU (sec. térmica)', fmt(r.cdtThermalV), 'V')}
    ${resRow('ΔU %', fmt(r.cdtThermalPct), '%')}
    ${resRow('ΔU ≤ ' + c.maxCdt + '%', fmt(r.cdtThermalPct) + '%', '', r.checkCdtThermal)}
  `);

  html += section('Sección Final', '#d4a030', `
    ${resRow('Sección FINAL', fmt(r.secFinal, 1), 'mm²', undefined, true)}
    ${resRow('Iz base final', fmt(r.izBaseFinal), 'A')}
    ${resRow('Iz corregida final', fmt(r.izCorrFinal), 'A')}
    ${resRow('ΔU final', fmt(r.cdtFinalV), 'V')}
    ${resRow('ΔU final %', fmt(r.cdtFinalPct), '%')}
    ${resRow('In ≤ Iz ∧ ΔU ≤ ' + c.maxCdt + '%', r.checkFinalCable ? 'CUMPLE' : 'NO CUMPLE', '', r.checkFinalCable)}
  `);

  html += section('Cortocircuito', '#aa5a5a', `
    ${resRow('Ik máx origen', fmt(r.ikMaxOrigin), 'kA')}
    ${resRow('Ik mín carga (calc)', fmt(r.ikMinLoad, 3), 'kA')}
    ${resRow('Icu protección', fmt(r.icu), 'kA')}
    ${resRow('Icu ≥ Ik máx', fmt(r.icu) + ' ≥ ' + fmt(r.ikMaxOrigin), '', r.checkIcu)}
    ${resRow('Factor k', fmt(r.kFactor, 0))}
    ${resRow('t máx admisible', fmt(r.tMaxSC, 3), 's')}
    ${resRow('t disparo', fmt(r.tClear, 2), 's')}
    ${resRow('t_disp ≤ t_máx', fmt(r.tClear, 2) + ' ≤ ' + fmt(r.tMaxSC, 3), '', r.checkThermalSC)}
  `);

  // Veredicto
  const ok = r.finalCheck;
  html += `<div class="verdict ${ok ? 'ok' : 'fail'}">
    <div class="verdict-sub" style="color:${ok ? '#80d0a0' : '#ffaaaa'}">Veredicto Final</div>
    <div class="verdict-main">${ok ? '✓ CUMPLE' : '✗ NO CUMPLE'}</div>
    <div class="verdict-detail" style="color:${ok ? '#a0e0c0' : '#ffcccc'}">
      ${c.material}/${c.insulation} — ${r.secFinal} mm² — Método ${c.method} — In ${r.In} A
    </div>
  </div>`;

  // Tabla resumen si hay más de un circuito calculado
  const calculados = Object.keys(results).filter(k => results[k] && !results[k].error);
  if (calculados.length > 1) {
    html += `<div style="margin-top:16px">`;
    html += section('Resumen Todos', '#5a7aaa', (() => {
      let t = `<div style="overflow-x:auto"><table class="summary-table">
        <tr><th>TAG</th><th>Ib</th><th>In</th><th>S.Térm</th><th>S.Final</th><th>ΔU%</th><th>Estado</th></tr>`;
      calculados.forEach(k => {
        const ci = circuits[k], ri = results[k];
        t += `<tr>
          <td>${ci.tag}</td>
          <td>${fmt(ri.Ib)}</td>
          <td>${ri.In}</td>
          <td>${ri.secThermal}</td>
          <td style="font-weight:700">${ri.secFinal}</td>
          <td>${fmt(ri.cdtFinalPct)}</td>
          <td>${badge(ri.finalCheck)}</td>
        </tr>`;
      });
      t += `</table></div>`;
      return t;
    })());
    html += `</div>`;
  }

  document.getElementById('content').innerHTML = html;
}

// ============================================
// ACCIONES
// ============================================

function setActive(i) { activeTab = i; render(); }

function setView(v) {
  currentView = v;
  document.getElementById('vDatos').className = 'vtab' + (v === 'edit' ? ' active' : '');
  document.getElementById('vResultados').className = 'vtab' + (v === 'results' ? ' active' : '');
  if (v === 'edit') renderEdit();
  else renderResults();
}

function updateField(name, value) {
  const numFields = ['power_kw','simult','utiliz','efficiency','voltage','cosPhi','length',
    'ambientTemp','kg','maxCdt','ikMax','icu','tClear'];
  const intFields = ['phases','loadedCond'];
  if (intFields.includes(name)) circuits[activeTab][name] = parseInt(value);
  else if (numFields.includes(name)) circuits[activeTab][name] = parseFloat(value) || 0;
  else circuits[activeTab][name] = value;
}

function updateFieldText(name, value) { circuits[activeTab][name] = value; }

function calcularUno() {
  results[activeTab] = calcular(circuits[activeTab]);
  setView('results');
  renderTabs();
  renderBottomBar();
}

function calcularTodos() {
  circuits.forEach((c, i) => { results[i] = calcular(c); });
  setView('results');
  renderTabs();
  renderBottomBar();
}

function addCircuit() {
  const n = circuits.length + 1;
  circuits.push({
    id:n, tag:String(n).padStart(3,'0'), desc:'Circuito ' + n,
    power_kw:0, simult:1.0, utiliz:1.0, efficiency:0.90,
    voltage:400, cosPhi:0.85, length:10, phases:3,
    startType:'None', method:'E', material:'Cu', insulation:'XLPE',
    loadedCond:3, ambientTemp:30, kg:1.0, maxCdt:5.0,
    ikMax:0, icu:10, tClear:0.1
  });
  activeTab = circuits.length - 1;
  currentView = 'edit';
  render();
}

function removeCircuit() {
  if (circuits.length <= 1) return;
  circuits.splice(activeTab, 1);
  delete results[activeTab];
  // Reindex results
  const newResults = {};
  Object.keys(results).forEach(k => {
    const ki = parseInt(k);
    if (ki < activeTab) newResults[ki] = results[ki];
    else if (ki > activeTab) newResults[ki - 1] = results[ki];
  });
  results = newResults;
  activeTab = Math.max(0, activeTab - 1);
  render();
}

function render() {
  renderTabs();
  if (currentView === 'edit') renderEdit();
  else renderResults();
  renderBottomBar();
}

// Iniciar
render();
</script>
</body>
</html>
