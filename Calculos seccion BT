// BASE DE DATOS NORMATIVA (UNE-HD 60364-5-52)
// ============================================

const SECTIONS = [1.5,2.5,4,6,10,16,25,35,50,70,95,120,150,185,240,300];
const PROT_SIZES = [6,10,13,16,20,25,32,40,50,63,80,100,125,160,200,250,315,400,500,630];

// Iz[método][material][aislamiento][conductores_cargados] = array indexado por SECTIONS
const IZ = {
  B1: {
    Cu: {
      XLPE: { 2:[20,27,37,47,65,87,110,137,167,214,259,301,343,391,468,538], 3:[17.5,24,32,41,57,76,96,119,144,184,223,259,299,341,403,464] },
